# Default Kokoro TTS endpoint used by all users (can still be overridden in voice settings)
VITE_KOKORO_TTS_URL=https://kokoro-api-production-9ea1.up.railway.app/v1/audio/speech

# Tencent CloudBase Auth + Cloud Progress Sync
# Example:
# VITE_CLOUDBASE_ENV_ID=your-env-id
# VITE_CLOUDBASE_REGION=ap-shanghai
# VITE_CLOUDBASE_PUBLISHABLE_KEY=your-publishable-key
# VITE_CLOUDBASE_PROGRESS_COLLECTION=user_progress
VITE_CLOUDBASE_ENV_ID=
VITE_CLOUDBASE_REGION=ap-shanghai
VITE_CLOUDBASE_PUBLISHABLE_KEY=
VITE_CLOUDBASE_PROGRESS_COLLECTION=user_progress
