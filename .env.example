# Default Kokoro TTS endpoint used by all users (can still be overridden in voice settings)
# Local self-hosted server: npm run tts:kokoro
VITE_KOKORO_TTS_URL=http://127.0.0.1:8880/v1/audio/speech

# Cloud example:
# VITE_KOKORO_TTS_URL=https://your-app.up.railway.app/v1/audio/speech

# Optional static word audio base. Keep empty for same-origin /audio/words.
# For R2/CDN, use a public base URL without the trailing voice/id filename.
# VITE_WORD_AUDIO_BASE_URL=https://pub-47e027cd6ce64af29a76f038ecb22373.r2.dev/audio/words

# Optional static example sentence audio base. Keep empty for same-origin /audio/examples.
# For R2/CDN, use a public base URL without the trailing voice/id filename.
# VITE_EXAMPLE_AUDIO_BASE_URL=https://pub-47e027cd6ce64af29a76f038ecb22373.r2.dev/audio/examples

# Local R2 upload helper. Keep secrets in your shell, not in committed env files.
# R2_AUDIO_BUCKET=english-flashcards-audio
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Optional API base (default uses same-origin /api on Cloudflare Worker)
# VITE_API_BASE=/api
VITE_API_BASE=/api
