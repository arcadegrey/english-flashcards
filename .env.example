# Default Kokoro TTS endpoint used by all users (can still be overridden in voice settings)
# Local self-hosted server: npm run tts:kokoro
VITE_KOKORO_TTS_URL=http://127.0.0.1:8880/v1/audio/speech

# Cloud example:
# VITE_KOKORO_TTS_URL=https://your-app.up.railway.app/v1/audio/speech

# Optional static word audio base. Keep empty for same-origin /audio/words.
# For R2/CDN, use a public base URL without the trailing voice/id filename.
# VITE_WORD_AUDIO_BASE_URL=https://cdn.example.com/audio/words

# Optional API base (default uses same-origin /api on Cloudflare Worker)
# VITE_API_BASE=/api
VITE_API_BASE=/api
